{
  "name": "rust-sets-pricing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "docker-compose up",
    "test": "node --test server/*.test.js",
    "stop": "docker-compose down",
    "clean": "docker-compose down -v",
    "front": "vite",
    "server": "node --watch server/index.js",
    "s3": "minio server /Users/max/minio-data --address :9000 --console-address :9001",
    "pg": "docker-compose up postgres",
    "kill:backend": "pkill -f 'server/index.js' || true",
    "kill:front": "pkill -f vite || true"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "vite": "^5.4.10"
  }
}
